# Deployment used by `npx convex dev`
# this should commented out if you use self-hosted
CONVEX_DEPLOYMENT="dev:<your-convex-deployment>"

VITE_CONVEX_URL="https://<your-convex-deployment>.convex.cloud"
# VITE_CONVEX_URL=http://127.0.0.1:3210 # Self-hosted convex

VITE_CONVEX_SITE_URL="https://<your-convex-deployment>.convex.site"
# VITE_CONVEX_SITE_URL=http://127.0.0.1:3211 # Self-hosted convex

# Self hosted convex
# Full guide: https://github.com/get-convex/convex-backend/blob/main/self-hosted/README.md
# CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
# CONVEX_SELF_HOSTED_ADMIN_KEY="<your-generated-admin-key>"

# Locale defaults — change per deployment
VITE_DEFAULT_TIMEZONE=Asia/Ho_Chi_Minh
VITE_DEFAULT_LOCALE=vi-VN # Available locales: vi-VN, en-US
VITE_SENTRY_DSN=
SENTRY_PROJECT=
SENTRY_ORG=
SENTRY_AUTH_TOKEN=
